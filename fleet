#!/usr/bin/env bash
# fleet — Source-mode runner (replaces compiled binary)
# Runs the TypeScript CLI directly via Bun for full, unbuffered output.
# The old bash CLI is preserved as fleet-legacy.sh in this directory.
set -eo pipefail

FLEET_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
exec bun run "${FLEET_ROOT}/src/index.ts" "$@"

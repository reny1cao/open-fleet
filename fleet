#!/bin/bash
# fleet — Agent fleet CLI
#
# Usage:
#   fleet start <agent> [workspace] [--role <role>] [--at <server>] [--wait] [--json]
#   fleet stop <agent> [--at <server>] [--json]
#   fleet inject <agent> <role>
#   fleet status [--json]
#   fleet init
#   fleet doctor [--json]
#   fleet deps [--install]
#   fleet patch [patch-name]
#   fleet help
#
# Exit codes:
#   0  success
#   1  usage error (bad arguments, unknown command)
#   2  config error (missing fleet.yaml, missing token, invalid YAML)
#   3  runtime error (SSH unreachable, tmux failure, token rejected)

set -eo pipefail

# ── Resolve script location and source libs ───────────────────────────────────

# Resolve symlinks to find the real script location
_fleet_source="${BASH_SOURCE[0]}"
while [[ -L "$_fleet_source" ]]; do
  _fleet_dir="$(cd "$(dirname "$_fleet_source")" && pwd)"
  _fleet_source="$(readlink "$_fleet_source")"
  [[ "$_fleet_source" != /* ]] && _fleet_source="$_fleet_dir/$_fleet_source"
done
SCRIPT_DIR="$(cd "$(dirname "$_fleet_source")" && pwd)"
FLEET_DIR="${FLEET_DIR:-$(pwd)}"

# Global flags (set before sourcing libs so they're available everywhere)
JSON_OUTPUT=false
QUIET_OUTPUT=false

source "$SCRIPT_DIR/lib/ui.sh"
source "$SCRIPT_DIR/lib/config.sh"
source "$SCRIPT_DIR/lib/remote.sh"
source "$SCRIPT_DIR/lib/identity.sh"
source "$SCRIPT_DIR/lib/init.sh"
source "$SCRIPT_DIR/lib/doctor.sh"
source "$SCRIPT_DIR/lib/deps.sh"
source "$SCRIPT_DIR/lib/patch.sh"

# ── JSON helpers ──────────────────────────────────────────────────────────────

# ── Output helpers ─────────────────────────────────────────────────────────

# Print to stdout (suppressed in --quiet mode unless --json)
say() {
  $QUIET_OUTPUT && ! $JSON_OUTPUT && return
  echo "$@"
}

# Print error to stderr (always visible; JSON-structured if --json)
# Usage: err "message" [key value ...] — first arg is the human-readable message
#   JSON mode:  {"error": "message", key: value, ...} to stderr
#   Plain mode: "Error: message" to stderr
err() {
  local message="$1"; shift
  if $JSON_OUTPUT; then
    json_obj "error" "$message" "$@" >&2
  else
    echo "Error: $message" >&2
  fi
}

json_kv() {
  # json_kv key value — outputs "key": "value" (escapes quotes in value)
  local v="${2//\"/\\\"}"
  printf '"%s": "%s"' "$1" "$v"
}

json_obj() {
  # json_obj "k1" "v1" "k2" "v2" ... — outputs { "k1": "v1", "k2": "v2" }
  local out="{"
  local first=true
  while [[ $# -ge 2 ]]; do
    $first || out="$out,"
    out="$out $(json_kv "$1" "$2")"
    first=false
    shift 2
  done
  echo "$out }"
}

# ── Commands ──────────────────────────────────────────────────────────────────

do_start() {
  local agent="$1" custom_dir="$2" role="$3" server_override="$4" wait_flag="$5"
  require_config

  # Validate agent exists
  local agents
  agents=$(list_agents)
  if ! echo "$agents" | grep -qx "$agent"; then
    err "unknown agent '$agent'" "agent" "$agent"
    exit 1
  fi

  local token server state_dir workspace session plugin runtime
  token=$(get_token "$agent")
  server="${server_override:-$(agent_get "$agent" "server" 2>/dev/null || echo "local")}"
  state_dir=$(agent_get "$agent" "state_dir" 2>/dev/null || true)
  workspace="${custom_dir:-$(agent_get_or_default "$agent" "workspace" 2>/dev/null || echo "~/workspace")}"
  session=$(session_name "$agent")
  plugin=$(channel_plugin)
  runtime=$(runtime_binary)

  if [[ -z "$token" ]]; then
    local env_name
    env_name=$(agent_get "$agent" "token_env" 2>/dev/null || echo "?")
    err "$env_name not set — check .env" "agent" "$agent" "token_env" "$env_name"
    exit 2
  fi

  if [[ "$server" == "local" ]]; then
    # ── Local start ──
    local expanded_work="${workspace/#\~/$HOME}"
    local expanded_state="${state_dir/#\~/$HOME}"

    if [[ ! -d "$expanded_work" ]]; then
      err "directory not found: $expanded_work" "path" "$expanded_work"
      exit 2
    fi

    if tmux has-session -t "$session" 2>/dev/null; then
      if $JSON_OUTPUT; then
        json_obj "agent" "$agent" "state" "already_running" "session" "$session"
      else
        say "$agent is already running. Attach: tmux attach -t $session"
      fi
      exit 0
    fi

    local cmd="DISCORD_BOT_TOKEN=$token FLEET_SELF=$agent"
    [[ -n "$expanded_state" ]] && cmd="$cmd DISCORD_STATE_DIR=$expanded_state"
    cmd="$cmd $runtime --dangerously-skip-permissions --channels $plugin"

    say "Starting $agent (local)..."
    say "  Workspace: $expanded_work"
    tmux new-session -d -s "$session" -c "$expanded_work" "$cmd"

    if [[ "$wait_flag" == "true" ]]; then
      say "  Waiting for identity injection..."
      inject_identity "$agent" "$session" "local" "$role"
    else
      inject_identity "$agent" "$session" "local" "$role" &
    fi

    if $JSON_OUTPUT; then
      json_obj "agent" "$agent" "state" "started" "server" "local" "session" "$session" "workspace" "$expanded_work"
    else
      say "  ✔ $agent started. Attach: tmux attach -t $session"
    fi

  else
    # ── Remote start ──
    local ssh_host remote_user
    ssh_host=$(server_ssh_host "$server") || {
      err "no ssh_host configured for server '$server'" "server" "$server"
      exit 3
    }
    remote_user=$(server_user "$server")

    if session_exists "$session" "$server"; then
      if $JSON_OUTPUT; then
        json_obj "agent" "$agent" "state" "already_running" "server" "$server"
      else
        say "$agent is already running at $server"
      fi
      exit 0
    fi

    local remote_start="export PATH=\$HOME/.bun/bin:\$PATH && DISCORD_BOT_TOKEN=$token FLEET_SELF=$agent"
    [[ -n "$state_dir" ]] && remote_start="$remote_start DISCORD_STATE_DIR=$state_dir"
    remote_start="$remote_start $runtime --dangerously-skip-permissions --channels $plugin"

    say "Starting $agent ($server via SSH)..."
    say "  Workspace: $workspace"
    remote_cmd "$ssh_host" "$remote_user" "tmux new-session -d -s $session -c $workspace \"$remote_start\"" 2>&1

    if [[ "$wait_flag" == "true" ]]; then
      say "  Waiting for identity injection..."
      inject_identity "$agent" "$session" "$server" "$role"
    else
      inject_identity "$agent" "$session" "$server" "$role" &
    fi

    if $JSON_OUTPUT; then
      json_obj "agent" "$agent" "state" "started" "server" "$server" "session" "$session"
    else
      say "  ✔ $agent started at $server"
    fi
  fi
}

do_stop() {
  local agent="$1" server_override="$2"
  require_config

  # FLEET_SELF protection: don't stop yourself
  if [[ -n "${FLEET_SELF:-}" && "$agent" == "$FLEET_SELF" ]]; then
    echo "Error: cannot stop yourself ($FLEET_SELF). Use --force to override." >&2
    exit 5
  fi

  # Validate agent exists
  local agents
  agents=$(list_agents)
  if ! echo "$agents" | grep -qx "$agent"; then
    err "unknown agent '$agent'" "agent" "$agent"
    exit 1
  fi

  local server session
  server="${server_override:-$(agent_get "$agent" "server" 2>/dev/null || echo "local")}"
  session=$(session_name "$agent")

  if [[ "$server" == "local" ]]; then
    if tmux kill-session -t "$session" 2>/dev/null; then
      if $JSON_OUTPUT; then
        json_obj "agent" "$agent" "state" "stopped" "server" "local"
      else
        say "✔ $agent stopped"
      fi
    else
      if $JSON_OUTPUT; then
        json_obj "agent" "$agent" "state" "not_running" "server" "local"
      else
        say "$agent is not running"
      fi
    fi
  else
    local ssh_host remote_user
    ssh_host=$(server_ssh_host "$server") || {
      err "no ssh_host configured for server '$server'" "server" "$server"
      exit 3
    }
    remote_user=$(server_user "$server")
    if remote_cmd "$ssh_host" "$remote_user" "tmux kill-session -t $session" 2>/dev/null; then
      if $JSON_OUTPUT; then
        json_obj "agent" "$agent" "state" "stopped" "server" "$server"
      else
        say "✔ $agent stopped at $server"
      fi
    else
      if $JSON_OUTPUT; then
        json_obj "agent" "$agent" "state" "not_running" "server" "$server"
      else
        say "$agent is not running at $server"
      fi
    fi
  fi
}

do_status() {
  require_config

  local prefix
  prefix=$(yaml_get "fleet.name" 2>/dev/null || echo "fleet")

  if $JSON_OUTPUT; then
    local first=true
    echo "["
    for agent in $(list_agents); do
      local server session state role
      server=$(agent_get "$agent" "server" 2>/dev/null || echo "local")
      session=$(session_name "$agent")
      state=$(session_state "$session" "$server")
      role=$(agent_get "$agent" "role" 2>/dev/null || echo "")

      $first || echo ","
      json_obj "name" "$agent" "server" "$server" "state" "$state" "role" "$role" "session" "$session"
      first=false
    done
    echo ""
    echo "]"
    return
  fi

  echo "=== $prefix Fleet ==="

  for agent in $(list_agents); do
    local server session state role
    server=$(agent_get "$agent" "server" 2>/dev/null || echo "local")
    session=$(session_name "$agent")
    state=$(session_state "$session" "$server")
    role=$(agent_get "$agent" "role" 2>/dev/null || echo "")

    local label="$agent ($server)"
    [[ -n "$role" ]] && label="$agent ($server, $role)"

    case "$state" in
      running)     printf "  ${green}[on]${reset}  %s" "$label"
                   [[ "$server" == "local" ]] && printf " — tmux attach -t $session"
                   echo "" ;;
      stopped)     printf "  ${dim}[off]${reset} %s\n" "$label" ;;
      unreachable) printf "  ${yellow}[??]${reset}  %s — SSH unreachable\n" "$label" ;;
    esac
  done
}

do_inject() {
  local agent="$1" role="$2"
  require_config

  # Validate agent exists
  local agents
  agents=$(list_agents)
  if ! echo "$agents" | grep -qx "$agent"; then
    echo "Error: unknown agent '$agent'"
    exit 1
  fi

  hot_inject_role "$agent" "$role"
}

do_apply() {
  require_config

  local prefix
  prefix=$(yaml_get "fleet.name" 2>/dev/null || echo "fleet")

  if ! $JSON_OUTPUT; then
    echo "Applying $prefix fleet..."
    echo ""
  fi

  local results=() failed=0

  for agent in $(list_agents); do
    local server session state
    server=$(agent_get "$agent" "server" 2>/dev/null || echo "local")
    session=$(session_name "$agent")
    state=$(session_state "$session" "$server")

    if [[ "$state" == "running" ]]; then
      if ! $JSON_OUTPUT; then
        echo "  ✔ $agent ($server) — already running"
      fi
      results+=("{\"agent\":\"$agent\",\"state\":\"already_running\",\"server\":\"$server\"}")
    else
      if ! $JSON_OUTPUT; then
        echo "  Starting $agent ($server)..."
      fi

      # Build start args
      local token workspace_dir state_dir plugin runtime
      token=$(get_token "$agent")
      workspace_dir=$(agent_get_or_default "$agent" "workspace" 2>/dev/null || echo "~/workspace")
      state_dir=$(agent_get "$agent" "state_dir" 2>/dev/null || true)
      plugin=$(channel_plugin)
      runtime=$(runtime_binary)

      if [[ -z "$token" ]]; then
        if ! $JSON_OUTPUT; then echo "  ✘ $agent — token not set"; fi
        results+=("{\"agent\":\"$agent\",\"state\":\"error\",\"error\":\"token not set\"}")
        failed=$((failed + 1))
        continue
      fi

      # Start the agent (reuse do_start logic inline for simplicity)
      local saved_json=$JSON_OUTPUT
      JSON_OUTPUT=false
      do_start "$agent" "" "" "" "true" 2>/dev/null
      JSON_OUTPUT=$saved_json

      local new_state
      new_state=$(session_state "$session" "$server")
      if [[ "$new_state" == "running" ]]; then
        if ! $JSON_OUTPUT; then echo "  ✔ $agent ($server) — started"; fi
        results+=("{\"agent\":\"$agent\",\"state\":\"started\",\"server\":\"$server\"}")
      else
        if ! $JSON_OUTPUT; then echo "  ✘ $agent ($server) — failed to start"; fi
        results+=("{\"agent\":\"$agent\",\"state\":\"error\",\"server\":\"$server\"}")
        failed=$((failed + 1))
      fi
    fi
  done

  if $JSON_OUTPUT; then
    echo "[$(IFS=,; echo "${results[*]}")]"
  else
    echo ""
    local total=${#results[@]}
    echo "  $((total - failed))/$total agents running."
  fi

  return $failed
}

usage() {
  local agents roles
  agents=$(list_agents 2>/dev/null | tr '\n' ' ' || echo "(no fleet.yaml found)")
  roles=$(available_roles 2>/dev/null || echo "")

  cat <<EOF
fleet — Agent fleet CLI

Usage:
  fleet init                                     First-time setup wizard
  fleet start <agent> [--role <r>] [--wait] [--json]  Start an agent
  fleet stop <agent> [--at <server>] [--json]    Stop an agent
  fleet inject <agent> <role>                    Hot-inject role
  fleet apply [--json]                            Start all agents from fleet.yaml
  fleet status [--json]                          Fleet overview
  fleet doctor [--json]                          Health check
  fleet deps [--install]                         Check/install dependencies
  fleet patch [name]                             Apply Discord plugin patches
  fleet help                                     This help

Flags:
  --json    Machine-readable JSON output (for agent/script consumption)
  --quiet   Minimal output, errors only (for pipelines)
  --wait    Block until identity injection completes (fleet start)

Exit codes:
  0  success
  1  usage error (bad arguments, unknown agent/command)
  2  config error (missing fleet.yaml, missing token, bad YAML)
  3  runtime error (SSH unreachable, tmux failure)

Agents: $agents
Roles:  ${roles:-"(none)"}

Examples:
  fleet init                                   # Interactive setup
  fleet start hub                              # Default server + workspace
  fleet apply                                  # Start all agents
  fleet start hub --wait --json                # Agent-friendly: wait + JSON
  fleet start worker --role writer             # Start with role overlay
  fleet stop worker                            # Stop at default server
  fleet status --json                          # JSON for agent parsing
  fleet doctor --json                          # JSON diagnostics
  fleet deps --install                         # Auto-install missing deps
  fleet patch                                  # Apply all Discord patches
EOF
}

# ── Argument parsing ──────────────────────────────────────────────────────────

parse_start_args() {
  local agent="$1"; shift
  local custom_dir="" role="" at="" wait_flag="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role)  role="$2"; shift 2 ;;
      --at)    at="$2"; shift 2 ;;
      --wait)  wait_flag="true"; shift ;;
      --json)  JSON_OUTPUT=true; shift ;;
      --quiet) QUIET_OUTPUT=true; shift ;;
      *)       custom_dir="$1"; shift ;;
    esac
  done

  # Validate --at against known servers
  if [[ -n "$at" && "$at" != "local" ]]; then
    if ! list_servers | grep -qx "$at"; then
      err "unknown server '$at'" "server" "$at"
      exit 1
    fi
  fi

  do_start "$agent" "$custom_dir" "$role" "$at" "$wait_flag"
}

parse_stop_args() {
  local agent="$1"; shift
  local at="" force=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --at)    at="$2"; shift 2 ;;
      --json)  JSON_OUTPUT=true; shift ;;
      --quiet) QUIET_OUTPUT=true; shift ;;
      --force) force=true; shift ;;
      *)       shift ;;
    esac
  done

  # --force overrides FLEET_SELF protection
  if $force; then
    FLEET_SELF=""
  fi

  do_stop "$agent" "$at"
}

parse_status_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)  JSON_OUTPUT=true; shift ;;
      --quiet) QUIET_OUTPUT=true; shift ;;
      *)       shift ;;
    esac
  done
  do_status
}

parse_doctor_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)  JSON_OUTPUT=true; shift ;;
      --quiet) QUIET_OUTPUT=true; shift ;;
      *)       shift ;;
    esac
  done
  do_doctor
}

# ── Route ─────────────────────────────────────────────────────────────────────

ACTION="${1:-help}"
AGENT="${2:-}"

case "$ACTION" in
  start)
    [[ -z "$AGENT" ]] && { echo "Usage: fleet start <agent> [workspace] [--role <role>] [--at <server>] [--wait] [--json]"; exit 1; }
    shift 2
    parse_start_args "$AGENT" "$@"
    ;;
  stop)
    [[ -z "$AGENT" ]] && { echo "Usage: fleet stop <agent> [--at <server>] [--json]"; exit 1; }
    shift 2
    parse_stop_args "$AGENT" "$@"
    ;;
  inject)
    [[ -z "$AGENT" ]] && { echo "Usage: fleet inject <agent> <role>"; exit 1; }
    do_inject "$AGENT" "${3:-}"
    ;;
  apply)
    shift
    while [[ $# -gt 0 ]]; do
      case "$1" in --json) JSON_OUTPUT=true; shift ;; *) shift ;; esac
    done
    do_apply
    ;;
  status)
    shift
    parse_status_args "$@"
    ;;
  init)
    shift 1
    do_init "$@"
    ;;
  doctor)
    shift
    parse_doctor_args "$@"
    ;;
  deps)
    do_deps "${2:-}"
    ;;
  patch)
    do_patch "${2:-all}"
    ;;
  help|--help|-h)
    usage
    ;;
  version|--version|-v)
    echo "fleet 0.1.0"
    ;;
  *)
    echo "Unknown command: $ACTION"
    echo ""
    usage
    exit 1
    ;;
esac

{
  "name": "open-fleet",
  "version": "0.1.0",
  "type": "module",
  "bin": { "fleet": "src/index.ts" },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --outfile fleet-bin src/index.ts",
    "build:remote": "bun build --target bun --outfile fleet-remote.mjs src/index.ts",
    "install-cli": "ln -sf \"$(pwd)/fleet\" \"$HOME/.local/bin/fleet\"",
    "test": "bun test"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}

# ============================================================================
# fleet.yaml — Agent Fleet Configuration
# ============================================================================
#
# Single source of truth for fleet topology.
# Copy to fleet.yaml and customize, or run `fleet init` to generate.
#
# Usage:
#   fleet start hub                   # start one agent
#   fleet start hub --role writer     # start with role overlay
#   fleet status                      # fleet overview
#   fleet stop worker                 # stop one agent

# ── Fleet metadata ──────────────────────────────────────────────────────────

fleet:
  name: my-fleet                       # tmux prefix: my-fleet-<agent>

# ── Discord ───────────────────────────────────────────────────────────────────
# Centralized Discord IDs. Identity templates reference these via {{discord.*}}.

discord:
  server_id: "YOUR_DISCORD_SERVER_ID"
  user_id: "YOUR_DISCORD_USER_ID"      # fleet admin
  channels:
    general: "YOUR_GENERAL_CHANNEL_ID"
    dev: "YOUR_DEV_CHANNEL_ID"
    infra: "YOUR_INFRA_CHANNEL_ID"

# ── Servers ─────────────────────────────────────────────────────────────────
# SSH-reachable hosts. "local" is implicit — no config needed.

servers:
  staging:
    ssh_host: staging-server             # SSH config alias, or user@host
    user: dev                            # remote user to run as (default: current)
  # production:
  #   ssh_host: prod-server
  #   user: deploy

# ── Defaults ────────────────────────────────────────────────────────────────

defaults:
  agent: claude-code                     # agent type (claude-code for v0.1)
  runtime: claude                        # CLI binary name
  workspace: ~/workspace
  channel_plugin: plugin:discord@claude-plugins-official
  permissions: dangerously-skip          # required for unattended agents

# ── Agents ──────────────────────────────────────────────────────────────────
#
# Each agent = one tmux session + one Claude Code process.
#
# Required: token_env, server
# Optional: everything else (inherits from defaults)
#
# Fields:
#   token_env    env var holding the Discord bot token
#   server       "local" or a key from the servers section
#   role         freeform label (hub, worker, reviewer, etc.)
#   identity     path to identity markdown (relative to fleet.yaml)
#   workspace    working directory (overrides defaults.workspace)
#   state_dir    Discord plugin state dir (needed for multi-instance on same machine)
#   note         human-readable description (shown in docs, not used by CLI)

agents:
  hub:
    token_env: DISCORD_BOT_TOKEN_HUB
    role: hub
    server: local
    identity: identities/hub.md
    note: "Dispatcher — receives tasks, delegates to workers"

  worker-1:
    token_env: DISCORD_BOT_TOKEN_WORKER1
    role: worker
    server: local
    state_dir: ~/.fleet/state/discord-worker1
    identity: identities/worker-1.md
    note: "Local development execution"

  worker-2:
    token_env: DISCORD_BOT_TOKEN_WORKER2
    role: worker
    server: staging
    identity: identities/worker-2.md
    note: "Remote execution on staging server"

# ============================================================================
# fleet.yaml — Agent Fleet Configuration
# ============================================================================
#
# Copy to fleet.yaml and customize. This file replaces bot-pool.json as the
# single source of truth for fleet topology.
#
# Migration from bot-pool.json:
#   spawn.sh checks for fleet.yaml first, falls back to bot-pool.json.
#   Once you have fleet.yaml working, bot-pool.json can be deleted.
#
# Usage:
#   ./spawn.sh start sentinel         # start one agent
#   ./spawn.sh start sentinel --role writer  # start with role overlay
#   ./spawn.sh status                  # fleet status
#   ./spawn.sh stop pilot             # stop one agent

# ── Fleet metadata ──────────────────────────────────────────────────────────

fleet:
  name: hq
  channel: discord

# ── Servers ─────────────────────────────────────────────────────────────────
# Define SSH-reachable hosts. "local" is implicit — no config needed.

servers:
  singapore:
    ssh_host: sg-dev                    # SSH config alias, or user@host
    user: dev                           # remote user to run as (default: current)
  # germany:
  #   ssh_host: de-srv
  #   user: dev

# ── Defaults ────────────────────────────────────────────────────────────────

defaults:
  runtime: claude                       # agent CLI binary (claude, codex, etc.)
  workspace: ~/workspace
  channel_plugin: plugin:discord@claude-plugins-official
  permissions: dangerously-skip         # required for unattended bots
  tmux_prefix: hq                       # sessions: hq-sentinel, hq-pilot, etc.

# ── Agents ──────────────────────────────────────────────────────────────────
#
# Each agent maps to one tmux session + one process.
#
# Required: token_env, server
# Optional: everything else (inherits from defaults)
#
# Fields that map to current spawn.sh (bot-pool.json compatibility):
#   token_env   → environment variable holding Discord bot token
#   state_dir   → custom Discord plugin state dir (for multi-instance)
#   server      → "local" or a key from servers section
#   workspace   → working directory (overrides defaults.workspace)
#   identity    → path to identity markdown file
#   role        → freeform label used in status display
#
# New fields (forward-looking, spawn.sh will grow into these):
#   runtime     → agent binary override (claude, codex, custom)
#   model       → LLM model override
#   flags       → extra CLI flags
#   startup_msg → posted to Discord when agent comes online

agents:
  sentinel:
    token_env: DISCORD_BOT_TOKEN_SENTINEL
    role: hub
    server: local
    identity: identities/sentinel.md
    workspace: ~/workspace
    note: "Hub — dispatches only, never does heavy work"

  pilot:
    token_env: DISCORD_BOT_TOKEN_PILOT
    role: guide
    server: local
    state_dir: ~/.claude/channels/discord-pilot
    identity: identities/pilot.md
    workspace: ~/workspace
    note: "Reads codebase, writes specs, reviews code"

  archon:
    token_env: DISCORD_BOT_TOKEN_ARCHON
    role: field-agent
    server: singapore
    identity: identities/archon.md
    note: "General-purpose execution on Singapore"

  forge:
    token_env: DISCORD_BOT_TOKEN_FORGE
    role: dev-worker
    server: singapore
    state_dir: ~/.claude/channels/discord-forge
    identity: identities/forge.md
    note: "Focused coding execution"

  citadel:
    token_env: DISCORD_BOT_TOKEN_CITADEL
    role: infra-worker
    server: germany
    state_dir: ~/.claude/channels/discord-citadel
    identity: identities/citadel.md
    note: "Infrastructure and ops"

# ── Runtime definitions (future) ────────────────────────────────────────────
# When spawn.sh supports multiple runtimes, define launch templates here.
#
# runtimes:
#   claude:
#     cmd: "claude --dangerously-skip-permissions --channels {{channel_plugin}}"
#     health: "pgrep -f 'claude.*--channels'"
#   codex:
#     cmd: "codex --approval-mode full-auto"
#     health: "pgrep -f codex"

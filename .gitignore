# Secrets — bot tokens, never commit
.env

# Bot pool config — contains bot IDs specific to your fleet
bot-pool.json

# Active identity files — contain your real bot IDs and channel IDs
# Only .md.example templates are tracked; actual .md identities are personal config
identities/*.md
!identities/_discord-formatting.md
!identities/roles/

.DS_Store

# Runtime state — generated by fleet start, contains real bot IDs
state/

# Global config — contains local paths
config.json

# Bun/TS build artifacts
node_modules/
fleet-next
dist/
*.bun-build
.*.bun-build
